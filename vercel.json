{
    "builds": [
        {
            "src": "app.py",
            "use": "@vercel/python"
        },
        {
            "src": "static/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/static/(.*)",
            "dest": "/static/$1",
            "headers": {
                "Cache-Control": "public, max-age=31536000, immutable"
            }
        },
        {
            "src": "/favicon.ico",
            "dest": "/static/assets/etohlock.png",
            "headers": {
                "Cache-Control": "public, max-age=86400"
            }
        },
        {
            "src": "/(.*)",
            "dest": "app.py"
        }
    ]
}